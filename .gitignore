# Build
target/
dependency-reduced-pom.xml

# Empacotamento do instalador (gerado por package-installer.ps1; publicado como asset do
# GitHub Release)
jpackage-input/
jpackage-content/
release-installer/
transcritor-ata-*.msi

# Eclipse
.project
.classpath
.settings/
bin/

# IntelliJ (por precaucao)
.idea/
*.iml

# Logs
logs/
*.log

# Modelos (grandes, nao versionar) -- mas NAO os modelos embutidos no jar (src/main/resources/models),
# que sao pequenos e essenciais ao build (ONNX de diarizacao + VAD do whisper.cpp).
*.bin
/models/
!src/main/resources/models/
!src/main/resources/models/*.bin

# Ferramentas de terceiros baixadas localmente (LIUM_SpkDiarization, etc.)
tools/

# Arquivos temporarios
*.tmp
*.wav

# Configuracao local do usuario (pode conter chave de API)
config.properties

# SO
Thumbs.db
.DS_Store
